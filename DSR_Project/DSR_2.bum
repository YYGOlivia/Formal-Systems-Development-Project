    <org.eventb.core.event name="C" org.eventb.core.comment="//Le site emetteur recoit un timeout signalant que le message a été perdu, il le prépare pour un nouvel envoi" org.eventb.core.convergence="0" org.eventb.core.extended="true" org.eventb.core.label="RecevoirTimeout">
